{
  "name": "link-shortener",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "db:create": "wrangler d1 create link-shortener-db",
    "db:migrate": "wrangler d1 migrations apply link-shortener-db",
    "db:migrate:local": "wrangler d1 migrations apply link-shortener-db --local"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.7.2",
    "wrangler": "^4"
  },
  "dependencies": {
    "hono": "^4.6.12"
  }
}
