{
  "name": "r2-storage",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-01",
  "vars": {
    "PUBLIC_BUCKET_URL": ""
  },
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "r2-storage-bucket"
    },
    {
      "binding": "PUBLIC_BUCKET",
      "bucket_name": "r2-storage-public"
    }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
