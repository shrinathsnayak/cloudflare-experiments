# IndexNow ownership key (8–128 chars: letters, numbers, dashes).
# Generate with: openssl rand -hex 16
# Set the same value in Vercel → Environment Variables (Production).
# Served publicly at /indexnow-key.txt for search-engine verification.
INDEXNOW_KEY=

# Shared secret for POST /api/indexnow.
# Use the same value as the Vercel webhook secret (Team/Project → Webhooks).
# Also works as Bearer token for a manual curl to /api/indexnow.
INDEXNOW_WEBHOOK_SECRET=
